; **********************************************************
; ***  DivRemNew - Unsigned integer division and remainder  ***
; ***  rc := ra DIV rb; ra := ra REM rb                  ***
; ***  rb preserved, rtemp corrupt                       ***
; ***  omits remainder (-> ra corrupt) if "$norem" <> "" ***
; ***  rb can be a constant if it starts with '#'        ***
; **********************************************************
        MACRO
$label  DivRemNew  $rc, $ra, $rb, $rtemp, $norem
$label
     [ NoARMVE
        MOV     $rtemp, $rb
        CMP     $rtemp, $ra, LSR #1
01
        MOVLS   $rtemp, $rtemp, LSL #1
        CMPLS   $rtemp, $ra, LSR #1
        BLS     %BT01
        MOV     $rc, #0
02
        CMP     $ra, $rtemp
        SUBCS   $ra, $ra, $rtemp
        ADC     $rc, $rc, $rc
        MOV     $rtemp, $rtemp, LSR #1
        CMP     $rtemp, $rb
        BCS     %BT02
     |
      [ ("$rb" :LEFT: 1) = "#"
        MOV     $rtemp, $rb
        UDIV    $rc, $ra, $rtemp
       [ "$norem" = ""
        MLS     $ra, $rtemp, $rc, $ra
       ]
      |
        UDIV    $rc, $ra, $rb
       [ "$norem" = ""
        MLS     $ra, $rb, $rc, $ra
       ]
      ]
     ]
        MEND

